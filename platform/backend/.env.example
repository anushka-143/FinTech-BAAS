# ─── Database ───
DATABASE_URL=postgresql+asyncpg://fintech:fintech_secret@localhost:5432/fintech_platform
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── Auth / Security ───
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080
HMAC_SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# ─── Redpanda / Kafka ───
REDPANDA_BOOTSTRAP_SERVERS=localhost:19092

# ─── Temporal ───
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=fintech-platform

# ─── OpenAI (AI Intelligence Layer) ───
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REASONING_MODEL=gpt-4o

# ─── Object Storage (S3-compatible / MinIO) ───
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_DOCUMENTS=fintech-documents

# ─── Banking Partner (our own bank connections) ───
# In sandbox: simulated locally, no real bank calls
# In production: connects to partner bank APIs
BANK_PARTNER_ID=
BANK_PARTNER_API_KEY=
BANK_PARTNER_API_SECRET=
BANK_PARTNER_BASE_URL=http://localhost:8001

# ─── Observability ───
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─── App ───
ENVIRONMENT=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000
